# 千牛云呼叫中心一键 Docker 部署配置
# 复制为 .env 后按需修改；不复制也可以使用 docker-compose.yml 内置默认值。

# GitHub Actions 推送镜像的位置。
# 如果仓库在你自己的 GitHub 账号下，把 IMAGE_NAMESPACE 改成你的 GitHub 用户名或组织名。
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=qianniuyun
IMAGE_TAG=latest

# 对外访问端口。
AGENT_WORKSPACE_PORT=5173
ADMIN_PORTAL_PORT=5174
API_GATEWAY_PORT=8888
WS_GATEWAY_PORT=8889
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
REDIS_PORT=6379
KAFKA_HOST_PORT=29092

# 初始登录账号。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2025

# 基础设施密码。正式上线前必须修改。
REDIS_PASSWORD=qianniu@2025
MINIO_ROOT_USER=qianniu
MINIO_ROOT_PASSWORD=qianniu@2025
JWT_SECRET=qianniuyun-callcenter-jwt-secret-key-2025-min32chars
